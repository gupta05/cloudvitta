# ─────────────────────────────────────────────────────────────
# CloudVitta Frontend — environment template
# Copy to `frontend/.env` only if you need to override defaults.
# Vite exposes vars prefixed with VITE_ to the browser, so NEVER
# put secrets here.
# ─────────────────────────────────────────────────────────────

# API base URL.
# NOTE: currently UNUSED — the app hardcodes `/api` and relies on the
# Vite dev proxy (see vite.config.js). Kept for future deployments where
# the frontend is served separately from the backend.
# VITE_API_URL="http://localhost:3000/api"
