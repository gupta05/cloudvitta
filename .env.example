# ─────────────────────────────────────────────────────────────
# CloudVitta — environment variable reference (aggregate)
#
# This is an overview of ALL environment variables in the project.
# The actual files each service loads are:
#   • backend/.env   ← copy from backend/.env.example  (all vars below)
#   • frontend/.env  ← copy from frontend/.env.example  (VITE_ vars only, optional)
#
# NEVER commit a real .env — only these *.env.example templates are tracked.
# ─────────────────────────────────────────────────────────────

# ===== Backend (backend/.env) =====

# Core
PORT=3000
DATABASE_URL="file:./dev.db"

# JWT signing. REQUIRED — server returns 500 if unset.
JWT_SECRET="change-me-to-a-long-random-secret"
JWT_EXPIRY="7d"

# Oracle Cloud Object Storage (S3-compatible)
OCI_S3_ENDPOINT=https://<namespace>.compat.objectstorage.<region>.oraclecloud.com
OCI_S3_BUCKET=cloudvitta-storage
OCI_S3_ACCESS_KEY_ID=<your-oci-access-key-id>
OCI_S3_SECRET_ACCESS_KEY=<your-oci-secret-access-key>
OCI_S3_REGION=ap-mumbai-1

# Platform-wide storage cap across all users, in GB
GLOBAL_STORAGE_CAP_GB=15

# Brevo (Sendinblue) transactional email — OTP delivery
BREVO_API_KEY=<your-brevo-api-key>
BREVO_SENDER_EMAIL=noreply@example.com
BREVO_SENDER_NAME=CloudVitta

# Razorpay (Test Mode — swap to live keys for production, no code change needed)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=<your-razorpay-key-secret>
RAZORPAY_WEBHOOK_SECRET=<your-razorpay-webhook-secret>

# Days after currentPeriodEnd before a lapsed paid subscription is downgraded to Free
RENEWAL_GRACE_DAYS=3

# ===== Frontend (frontend/.env — optional) =====

# Currently UNUSED (app hardcodes /api + Vite proxy). Kept for future split deploys.
# VITE_API_URL="http://localhost:3000/api"
