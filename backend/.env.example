# ─────────────────────────────────────────────────────────────
# CloudVitta Backend — environment template
# Copy this file to `backend/.env` and fill in real values.
# NEVER commit the real .env — it is gitignored.
# ─────────────────────────────────────────────────────────────

# --- Core ---
PORT=3000
DATABASE_URL="file:./dev.db"

# JWT signing. REQUIRED — the server returns 500 if unset.
# Generate a strong random secret, e.g. `openssl rand -base64 48`.
JWT_SECRET="change-me-to-a-long-random-secret"
JWT_EXPIRY="7d"

# --- Oracle Cloud Object Storage (S3-compatible) ---
# Create a Customer Secret Key in the OCI console (Identity → Users → Customer Secret Keys).
OCI_S3_ENDPOINT=https://<namespace>.compat.objectstorage.<region>.oraclecloud.com
OCI_S3_BUCKET=cloudvitta-storage
OCI_S3_ACCESS_KEY_ID=<your-oci-access-key-id>
OCI_S3_SECRET_ACCESS_KEY=<your-oci-secret-access-key>
OCI_S3_REGION=ap-mumbai-1

# Platform-wide storage cap across all users, in GB.
GLOBAL_STORAGE_CAP_GB=15

# --- Brevo (Sendinblue) transactional email — OTP delivery ---
# 1. https://app.brevo.com → Settings → SMTP & API → API Keys → Generate a new API key
# 2. Settings → Senders → add and verify a sender address
BREVO_API_KEY=<your-brevo-api-key>
BREVO_SENDER_EMAIL=noreply@example.com
BREVO_SENDER_NAME=CloudVitta

# --- Razorpay (Test Mode — swap to live keys for production, no code change) ---
# Test keys: https://dashboard.razorpay.com → Settings → API Keys (Test Mode)
# Webhook secret: Settings → Webhooks → Add endpoint (.../api/payments/webhook/razorpay)
#   Subscribe to events: payment.captured, payment.failed, refund.processed
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=<your-razorpay-key-secret>
RAZORPAY_WEBHOOK_SECRET=<your-razorpay-webhook-secret>

# Days after currentPeriodEnd before a lapsed paid subscription is downgraded to Free.
RENEWAL_GRACE_DAYS=3
