{
  "name": "cloudvitta",
  "version": "1.0.0",
  "private": true,
  "description": "CloudVitta — Billing & Subscription Management Platform",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "dev:backend": "npm run dev --workspace=backend",
    "dev:frontend": "npm run dev --workspace=frontend",
    "db:push": "npm run db:push --workspace=backend",
    "db:seed": "npm run db:seed --workspace=backend",
    "db:studio": "npm run db:studio --workspace=backend",
    "setup": "npm install && npm run db:push && npm run db:seed"
  }
}
